# =============================================================================
# spatial-pinwheel — Environment Variables
# =============================================================================
# Setup: cp .env.example .env  then fill in your values
# NEVER commit .env to git — it is listed in .gitignore
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=dev
APP_PORT=8000                        # Uvicorn port (must match nginx proxy_pass)

# ── Security ──────────────────────────────────────────────────────────────────
# P1-04: Bearer token for all API endpoints.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty in dev to disable auth.
AUTH_TOKEN=

# P1-03: Comma-separated allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://bot:bot@localhost:5432/botdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
ALLOW_NO_REDIS=false

# ── Broker ────────────────────────────────────────────────────────────────────
# paper = mock data generator, tbank = T-Bank Invest gRPC
BROKER_PROVIDER=paper

TBANK_TOKEN=
TBANK_ACCOUNT_ID=
TBANK_SANDBOX=true

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=/api/v1
VITE_USE_MOCK=true
VITE_UI_DEMO_MODE=false
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# ── SSE / Worker ─────────────────────────────────────────────────────────────
SSE_KEEPALIVE_SECONDS=20
TF=1m

# ── AI / Integrations ────────────────────────────────────────────────────────
AI_PRIMARY_PROVIDER=claude
AI_FALLBACK_PROVIDERS=ollama,skip
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Telegram notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Internet collector cache ─────────────────────────────────────────────────
NEWS_CACHE_TTL_SEC=3600
MACRO_CACHE_TTL_SEC=14400
