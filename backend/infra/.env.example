# =============================================================================
# Trading Bot Environment Variables
# Copy to .env and adjust values for your environment
# =============================================================================

# --- Core ---
APP_ENV=production
APP_PORT=8000
FRONTEND_PORT=80
API_PREFIX=/api/v1
AUTH_TOKEN=
GIT_COMMIT=HEAD

# --- Database ---
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot
POSTGRES_DB=botdb
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Worker Runtime ---
TF=1m
UNIVERSE_SIZE=25
SIGNAL_INTERVAL_SECONDS=30

# --- Broker ---
BROKER_PROVIDER=paper
TBANK_TOKEN=
TBANK_ACCOUNT_ID=
TBANK_SANDBOX=false
LIVE_TRADING_ENABLED=false
TBANK_ORDER_TIMEOUT_SEC=15
TBANK_ORDER_POLL_INTERVAL_SEC=0.5

# --- Docker Images (for CD/Production) ---
# Leave empty for local builds, set for remote registry
API_IMAGE=ghcr.io/FIREguardSPB/spatial-pinwheel-api:latest
WORKER_IMAGE=ghcr.io/FIREguardSPB/spatial-pinwheel-worker:latest
FRONTEND_IMAGE=ghcr.io/FIREguardSPB/spatial-pinwheel-frontend:latest

# --- Registry (for rollback script) ---
REGISTRY=ghcr.io
REPO=FIREguardSPB/spatial-pinwheel

# Для live-торговли дополнительно включите LIVE_TRADING_ENABLED=true после проверки токена и account id.
