[Unit]
Description=Spatial Pinwheel API
After=network.target docker.service
Requires=network.target

[Service]
Type=simple
WorkingDirectory=%h/Projects/Money/spatial_pinwheel/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/Projects/Money/spatial_pinwheel/backend/.venv/bin/uvicorn apps.api.main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=3
KillSignal=SIGINT
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
