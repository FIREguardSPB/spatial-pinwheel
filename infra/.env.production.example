# =============================================================================
# Trading Bot - Production Environment Variables
# Copy to /var/www/trading/backend/.env on server
# =============================================================================

# Application
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# API Server
API_HOST=127.0.0.1
APP_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg://trading:trading_secure_password_change_me@localhost:5432/trading_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# T-Bank Invest API (получить на https://www.tbank.ru/invest/)
TBANK_TOKEN=your_tbank_token_here
TBANK_ACCOUNT_ID=your_account_id_here
TBANK_SANDBOX=true

# Security
AUTH_TOKEN=generate_secure_random_string_here_min_32_chars
TOKEN_ENCRYPTION_KEY=generate_fernet_key_here

# CORS (frontend URL)
CORS_ORIGINS=https://trading.chatpsy.online

# Worker Settings
WORKER_POLL_INTERVAL=1
WORKER_MAX_RETRIES=3
